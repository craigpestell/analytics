// tsconfig.json

{
    "compilerOptions": {
      "target": "es2016",
      "module": "commonjs",
      "lib": ["dom", "es2016", "esnext.asynciterable"],
      "moduleResolution": "node",
      "outDir": "./src/models",
      "strict": true,
      "strictPropertyInitialization": false,
      "sourceMap": true,
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true
    },
    "include": ["./src/js/**/*"],
  }